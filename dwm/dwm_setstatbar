# wifi
#
# short format: ssid
# long format: ssid, upspeed, downspeed, signal
getwifi() {
	wifi=$(~/.local/bin/wifi_getssid)

	if [ -z "$wifi" ]
	then
		echo "п‡« о‚± (disconnected)"
	else
		echo "п‡« о‚± $(~/.local/bin/wifi_getssid)"
	fi

	# echo "wifi: $(~/.local/bin/wifi_getssid)"
}

# volume
#
# short format: volume level
# no long format
getvolume() {
	ismuted=$(~/.local/bin/audio_ismuted)

	if [ "$ismuted" = "muted" ]
	then
		# why is the mute symbol a garbage can?
		# echo "пљ© о‚± $(~/.local/bin/audio_getvolume)%"
		echo "m о‚± $(~/.local/bin/audio_getvolume)"
	elif [ "$ismuted" = "not muted" ]
	then
		echo "пЂЁ о‚± $(~/.local/bin/audio_getvolume)%"
	fi
}

# brightness
#
# short format: brightness level
# no long format
getbrightness() {
	echo "пЃ‚ о‚± $(~/.local/bin/bright_getp)%"
}

# battery
#
# short format: battery level, status
# long format: battery level, status, time left
#
# TODO: (long format) display time left until full charge/time until dead
# TODO: if multiple batteries present, only display the first one
getbattery() {
	status=$(~/.local/bin/batt_getstatus)
	percent="$(~/.local/bin/batt_getp)%"

	if [ "$status" = "Discharging" ]
	then
		echo "п‰‚ о‚± $percent"
	elif [ "$status" = "Charging" ]
	then
		echo "пѓ§ о‚± $percent"
	elif [ "$status" = "Full" ]
	then
		echo "п‰Ђ о‚± $percent"
	else
		echo "e о‚± $percent"
	fi
}

# datetime
#
# short format: day of the week, 12 hour time
# long format: month/day/year, 24 hour time
getdatetime() {
	date="$(date +"%a")"
	time="$(date +"%I:%M %P")"

	echo "пЂ— о‚± $date $time"

	# date_long="$(date +"%m/%d/%Y")"
	# time_long="$(date +"%H:%M:%S")"

	# echo "date: $date_long $time_long"
}


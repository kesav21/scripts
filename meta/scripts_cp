#!/bin/sh

scriptsdir="$HOME/.local/scripts"
bindir="$HOME/.local/bin"

cd "$scriptsdir"
files=$(find . \( ! -regex '.*/\..*' \) -type f)

echo -e "\nclearing $bindir:\n"

rm -rfv $bindir && mkdir $bindir

echo -e "\nadding scripts to $bindir\n"

for file in $files
do
	if [ -x "$file" ]
	then
		ln -sv $(realpath $file) $bindir/$(basename $file)
	fi
done

echo ""


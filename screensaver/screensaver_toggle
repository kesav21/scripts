#!/bin/bash

# retrieve shared variables
source ~/.local/bin/screensaver_vars

# toggle dpms
md=$(~/.local/bin/dpms_toggle $standby_timeout $suspend_timeout $off_timeout)

# toggle xautolock
mx=$(~/.local/bin/xautolock_toggle $locker_timeout)

# send notification
~/.local/bin/dunst_screensaver "$md" "$mx"

